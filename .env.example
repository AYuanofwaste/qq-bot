# ── Bot 基础配置 ──
BOT_HOST=127.0.0.1
BOT_PORT=8080
BOT_TOKEN=
BOT_QQ=你的QQ号

# ── AI 聊天（必填） ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=

# ── Pixiv（二选一） ──
PIXIV_PHPSESSID=
PIXIV_REFRESH_TOKEN=

# ── B站 cookies（可选） ──
BILIBILI_COOKIES_FILE=

# ── TTS 语音合成（可选） ──
TTS_API=http://127.0.0.1:9880

# ── 百度翻译（TTS 中日英自动翻译，置空则关闭） ──
BAIDU_APP_ID=
BAIDU_SECRET_KEY=
