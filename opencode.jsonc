{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "jmcomic": {
      "type": "local",
      "command": ["python", "jmcomic/server.py"],
      "enabled": true
    },
    "pixiv": {
      "type": "local",
      "command": ["python", "pixiv/server.py"],
      "enabled": true
    },
    "bilibili": {
      "type": "local",
      "command": ["python", "bilibili/server.py"],
      "enabled": true
    }
  }
}
